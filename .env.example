# InvoiceFlow configuration
# Copy this file to .env and adjust values as needed.

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=1048576
LOG_BACKUP_COUNT=5

# Paths
DEFAULT_INPUT_DIR=invoices
DEFAULT_OUTPUT_DIR=output
DEFAULT_OUTPUT_FILE=output/invoices.xlsx
BENCHMARK_DIR=benchmarks

# Processor
# Number of worker processes: auto | integer
WORKERS=auto
# sequential | multiprocessing
PROCESSING_MODE=multiprocessing

# Excel
EXCEL_SHEET_INVOICES=Invoices
EXCEL_SHEET_LINE_ITEMS=LineItems

# Future extensions (placeholders)
# OCR_ENABLED=false
# AI_EXTRACTION_ENABLED=false
# AI_MODEL=gpt-4o-mini
